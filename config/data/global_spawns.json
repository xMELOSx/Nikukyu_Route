:27500,"coins":0,"description":"常に何らかの電波を発信していると言われる貴重な機器。ヴェルテハイモー値の変動に非常に敏感で、未知の異象が存在する可能性のある未知の領域の探索において、学者たちに多大な貢献をしている。"},{"id":"ritem_65e42259-fdc5-48eb-8df5-fa5d82985cd2","name":"「揺星」","textColor":"yellow","fans":20000,"coins":0,"description":"時の洗礼を経てもなお、寒光を失わぬ長刀。鞘から抜けば、星々さえその輝きに震える。"},{"id":"ritem_544b6c20-7304-449f-a84e-3195abbd5cc4","name":"雪映の滴","textColor":"yellow","fans":15000,"coins":0,"description":"華美な宝石のネックレス。目にするだけで、この世で最も美しきものとはこれだと悟らされる。"},{"id":"ritem_5598ae47-4cf5-41f8-a94e-3ffac5e87d74","name":"ひんやり痛み止め","textColor":"yellow","fans":12000,"coins":120,"description":"即効性のある痛み止め。頭痛でも足の痛みでも、1粒でたちまち痛みが消え去る。"},{"id":"ritem_ef2dd41d-ca94-4129-b30f-0968f0351cf5","name":"紫煙水晶","textColor":"yellow","fans":9999,"coins":96,"description":"「宝石は語らずとも、いかなる言葉より人の心を動かす」――ある著名な作家はそう語った。"},{"id":"ritem_936e95bd-11ee-428c-bb23-77d8f1902f20","name":"オーナメント「ジオメトリー」","textColor":"yellow","fans":5000,"coins":84,"description":"かつてある公爵が愛蔵していた「ジオメトリー」シリーズの一つだと言われている。だが残りの品々は、希少価値を高めようとしたある商人によって、全て砕かれてしまったという。"},{"id":"ritem_bd2f29c5-71c1-45ca-9bf7-8b8be1de4462","name":"青花の壺","textColor":"purple","fans":15000,"coins":0,"description":"古めかしい風合いの花瓶。考古学者であれ盗賊であれ、運ぶ際はくれぐれも丁寧に扱うこと。"},{"id":"ritem_f921692a-0e7d-460d-8c7c-0151e293bf05","name":"絵画「深き森」","textColor":"purple","fans":7500,"coins":0,"description":"名匠の手による芸術品。多くのコレクターが注目する逸品であり、その価値も極めて高い。"},{"id":"ritem_9419e4f9-0bfb-4f42-93f1-083692e3220f","name":"絵画「古城」","textColor":"purple","fans":6400,"coins":72,"description":"名匠の手による芸術品。多くのコレクターが注目する逸品であり、その価値も極めて高い。"},{"id":"ritem_0f8e6d58-b763-4371-9b52-e9b834ff0e2a","name":"紅釉の花瓶","textColor":"purple","fans":6400,"coins":72,"description":"古めかしい風合いの花瓶。考古学者であれ盗賊であれ、運ぶ際はくれぐれも丁寧に扱うこと。"},{"id":"ritem_df958f42-0cdb-4cd4-8f56-1136feac7816","name":"絵画「緑の原」","textColor":"purple","fans":5200,"coins":72,"description":"名匠の手による芸術品。多くのコレクターが注目する逸品であり、その価値も極めて高い。"},{"id":"ritem_674635af-acdc-465b-a85f-bf22f71f3186","name":"深緑の花瓶","textColor":"purple","fans":5000,"coins":72,"description":"古めかしい風合いの花瓶。考古学者であれ盗賊であれ、運ぶ際はくれぐれも丁寧に扱うこと。"},{"id":"ritem_dc4df27b-9f9e-4f41-a023-f823c631703c","name":"絵画「静物」","textColor":"purple","fans":4000,"coins":48,"description":"名匠の手による芸術品。多くのコレクターが注目する逸品であり、その価値も極めて高い。"},{"id":"ritem_c911230a-0292-47d8-8a5e-c90a528de035","name":"VCエナドリ","textColor":"purple","fans":4000,"coins":48,"description":"眠気が取れない？疲れが溜まってる？VCエナドリで、1日分のエネルギーをチャージ！"},{"id":"ritem_84503579-5576-41b8-8aff-eac807354090","name":"墨染の壺","textColor":"purple","fans":3000,"coins":48,"description":"墨のように真っ黒な広口壺。伝説によると、ある貧しい作家が紙と筆を買えず、焼けた木炭と家の瓶や壺で執筆の練習をしていたところ、いつしか壺の黒炭が消えなくなったという。後に人々は彼を記念して墨染の壺を作った。"},{"id":"ritem_d7eb83a3-a860-4a16-9569-361ecb3ad487","name":"蓄音機","textColor":"purple","fans":2800,"coins":48,"description":"音楽界の流行がどれだけ移り変わろうとも、前世紀のヒットソングを聴き続ける者は必ずいるものだ。"},{"id":"ritem_060d0e14-7d72-468b-95ec-808d06b50de8","name":"日本刀「断流」","textColor":"purple","fans":2500,"coins":48,"description":"極めて研究価値の高い日本刀。かつては戦場で無双の強さを誇ったが、今そこに残されているのは、古びた静寂だけだ。"},{"id":"ritem_57f1b607-a1ae-47ca-b898-12abf16170ab","name":"墨染の瓶","textColor":"purple","fans":2000,"coins":48,"description":"墨のように真っ黒な長首瓶。伝説によると、ある貧しい作家が紙と筆を買えず、焼けた木炭と家の瓶や壺で執筆の練習をしていたところ、いつしか瓶の黒炭が消えなくなったという。後に人々は彼を記念して墨染の瓶を作った。"},{"id":"ritem_6b8d7d04-0e61-44ea-841e-31866db61937","name":"水先案内人の望遠鏡","textColor":"purple","fans":1500,"coins":38,"description":"信念と変わらぬ夢を抱き、船首に立つ水夫はここから誰も到達したことのない世界の果てを望む。"},{"id":"ritem_dc67b766-a567-43b7-938f-dffe9cca61d6","name":"金角の月光","textColor":"purple","fans":1500,"coins":38,"description":"貴重な純金のネックレス。独特なデザインで、優雅な光沢を放ち、身につけると溶けた月光が首にかかっているように見える。"},{"id":"ritem_f7420f48-706a-45a9-9d7a-846eb47ac85e","name":"星探しの望遠鏡","textColor":"purple","fans":1200,"coins":38,"description":"かつては、たとえ微かな星影が見えただけでも、人々は思わず感嘆の声を上げたものだ。"},{"id":"ritem_fedf8a85-9ddd-48b9-a651-c59488980381","name":"金塊","textColor":"purple","fans":1000,"coins":0,"description":"数学の宿題で頭を抱えているなら、この金の延べ棒がどれほどの価値になるか、計算の練習台にしてみるのもいいかもしれない。"},{"id":"ritem_8ad2ab27-19f7-4966-a5ac-96ef4aa04b43","name":"ゲーム機","textColor":"blue","fans":999,"coins":24,"description":"小型で持ち運びに便利なのに、機能まで充実しているゲーム機。銀行員が休憩中によく遊んでいる。"},{"id":"ritem_e642b410-060c-4ff8-aac8-c92a3c2ed411","name":"みかんジュース","textColor":"blue","fans":900,"coins":3,"description":"甘酸っぱく爽やかなみかん味のドリンク。開ける前によく振ってから飲むのがおすすめ。"},{"id":"ritem_3d53178c-7cfd-40b7-826e-fad19b745a83","name":"金色の器","textColor":"blue","fans":800,"coins":3,"description":"金メッキされた大容量の容器。家に1つ置いておけば、あらゆる雑多なものを収納できそうだ。"},{"id":"ritem_802cc6ed-4b77-45a9-bac7-1cf9c1f3539a","name":"ファンホーテック製スマホ","textColor":"blue","fans":750,"coins":3,"description":"「ファンホーテック」社の最新モデル。従来より機能が大幅強化されたためか、依存性も格段に高くなっている。"},{"id":"ritem_db3468b1-745a-4a7b-835d-db16dd45f331","name":"青花の碗","textColor":"blue","fans":720,"coins":3,"description":"古風な趣のある青花磁器の碗。"},{"id":"ritem_590e78a9-5be1-44f7-a020-4165790b0106","name":"藍釉の瓶","textColor":"blue","fans":640,"coins":3,"description":"奇妙な形をした磁器の瓶。"},{"id":"ritem_6bce9fa9-4074-4bf7-937c-02e668f313a9","name":"ギュビポテチ","textColor":"blue","fans":600,"coins":3,"description":"にくきゅう銀行の職員用フリースナック。"},{"id":"ritem_15cbb8d4-147e-4cdc-875a-6287331d954e","name":"デジタルカメラ","textColor":"blue","fans":600,"coins":3,"description":"クラシックなデザインのデジタルカメラ。"},{"id":"ritem_64637d10-633b-4264-8584-13a361586848","name":"花彫の碗","textColor":"blue","fans":560,"coins":3,"description":"古風な趣のある青花磁器の碗。"},{"id":"ritem_2ac701b5-e686-438b-a9a4-ac0e1d6e6fa0","name":"絵画「独酌」","textColor":"blue","fans":500,"coins":0,"description":"名匠の手による芸術品。"},{"id":"ritem_338f0c86-1388-4c55-a0aa-f48c195ef99a","name":"ナクペイダ模型","textColor":"blue","fans":400,"coins":0,"description":"ナクペイダをモチーフに作られた模型。"},{"id":"ritem_41a9dc02-b3b0-4351-82ef-548c169f3afd","name":"ベリーシェイク","textColor":"blue","fans":400,"coins":0,"description":"にくきゅう銀行の職員用フリードリンク。"},{"id":"ritem_c61c909f-f078-4ea7-bcf4-e6e7e365c7ed","name":"絵画「追香」","textColor":"blue","fans":400,"coins":0,"description":"名匠の手による芸術品。"},{"id":"ritem_3eeed253-4743-4bf8-bc3e-612ea6d3e727","name":"浅緋祈フィギュア","textColor":"blue","fans":300,"coins":0,"description":"「出会い〜銀月のロンドで」の人気キャラ。"},{"id":"ritem_3593a768-6d1f-4f31-8c79-b28c19bb4de6","name":"絵画「花畑」","textColor":"blue","fans":300,"coins":0,"description":"名匠の手による芸術品。"},{"id":"ritem_138f4ad7-301c-4216-8c87-2963200fe8b6","name":"団三郎ぬいぐるみ","textColor":"green","fans":250,"coins":0,"description":"丁寧に作られた団三郎のぬいぐるみ。愛嬌たっぷりで、子どもの誕生日プレゼントにもぴったりの一品。"},{"id":"ritem_8874f65c-21b8-467c-9204-9526df588dc0","name":"絵画「脱構築」","textColor":"green","fans":200,"coins":0,"description":"名匠の手による芸術品。多くのコレクターが注目する逸品であり、その価値も極めて高い。"},{"id":"ritem_5160757e-f154-4985-b4f0-e713303bad83","name":"モフモフフィギュア","textColor":"green","fans":180,"coins":0,"description":"奇妙なポーズを決めたマッチョなモフモフ。見た目はワイルドだが、手触りは抜群だ。"},{"id":"ritem_f836daf9-8e31-4c89-a011-1a1edebd220a","name":"札束","textColor":"green","fans":100,"coins":0,"description":"ありったけ詰めておきな。迷っていて買えずにいた物を、買いに行こう。誰も君を責めたりしないから。"},{"id":"ritem_13cf11e5-b0db-4ff9-b2c8-ae4e3d350326","name":"招き猫","textColor":"green","fans":100,"coins":0,"description":"様々な店でよく見かける招き猫の置物。商売人に千客万来の幸運をもたらすと言われている。"},{"id":"ritem_9ef537f8-f0f8-4548-9edc-f7f7ce27958c","name":"ぶどう炭酸水","textColor":"green","fans":100,"coins":0,"description":"にくきゅう銀行の職員用フリードリンク。清涼感があり、眠気覚ましの効果も結構あるらしい。"},{"id":"ritem_060031e8-9068-48ed-a8da-4b0b0ee73938","name":"銀行書類・その一","textColor":"green","fans":80,"coins":0,"description":"ある重要な取引を記録した書類のようだ。表紙の「極秘」を無視して中身を見るのはやめておいたほうがいいだろう……"},{"id":"ritem_3fb3ab4f-d815-441e-87ef-1287732dc590","name":"銀行書類・その二","textColor":"green","fans":60,"coins":0,"description":"散らばった数枚の銀行書類。内容は銀行とある顧客が結んだ融資契約のようだ。"},{"id":"ritem_4c823550-0431-4eb9-8490-5e07f2afc152","name":"漫画『デュークK』","textColor":"green","fans":50,"coins":0,"description":"人気の邪道漫画。奇抜な画風と、斬新な設定やストーリー展開が多くのファンを魅了してやまない。"},{"id":"ritem_8f2cdd26-6867-444a-a1db-bcf64873948c","name":"銀行書類・その三","textColor":"green","fans":40,"coins":0,"description":"詳細な「にくきゅう銀行窓口業務マニュアル」。実用性が高く、紛失した場合は受付で再発行してもらえる。"},{"id":"ritem_21a87126-4666-42af-97b8-927577cc0450","name":"『月刊ロマンス』","textColor":"green","fans":30,"coins":0,"description":"大人気の少女漫画誌。内容は主にラブコメディで、タギドはここから何がしかのインスピレーションを得たようだ。"},{"id":"ritem_c89473ad-ca5c-4446-8767-91de04f33ee0","name":"銀行書類・その四","textColor":"green","fans":20,"coins":0,"description":"ある銀行員の分厚い従業員マニュアル。中の文字はびっしりと書かれており、抜群の催眠効果がある。"},{"id":"ritem_9b156ae5-5a54-439a-8c76-a7855c9ee548","name":"特製金貨","textColor":"green","fans":10,"coins":0,"description":"にくきゅう銀行が発行する特製金貨。ファンスと交換できる。キラキラと輝く小さく精巧な1枚に、思わず愛着が湧いてしまう。"}]}